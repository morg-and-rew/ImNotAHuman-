  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1f9839ff07fc3994aa17c3c6b5ecfd28, type: 3}
  m_Name: New Text Table
  m_EditorClassIdentifier: Assembly-CSharp-firstpass::PixelCrushers.Wrappers.TextTable
  m_languageKeys:
  - Default
  - ru
  m_languageValues: 0000000001000000
  m_fieldKeys: 060000000800000001000000050000000200000007000000090000000a0000000b0000000c0000000d000000040000000f0000000e00000010000000
  m_fieldValues:
  - m_fieldName: intro.quote.marc_aurelius
    m_keys: 0000000001000000
    m_values:
    - '"Everything we hear is an opinion, not a fact. Everything we see is a perspective,
      not the truth." - Marcus Aurelius'
    - "\xAB\u0412\u0441\u0435, \u0447\u0442\u043E \u043C\u044B \u0441\u043B\u044B\u0448\u0438\u043C,
      - \u044D\u0442\u043E \u043C\u043D\u0435\u043D\u0438\u0435, \u0430 \u043D\u0435
      \u0444\u0430\u043A\u0442. \u0412\u0441\u0435, \u0447\u0442\u043E \u043C\u044B
      \u0432\u0438\u0434\u0438\u043C, \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
      \u043F\u0435\u0440\u0441\u043F\u0435\u043A\u0442\u0438\u0432\u043E\u0439, \u0430
      \u043D\u0435 \u043F\u0440\u0430\u0432\u0434\u043E\u0439\xBB\\r\\n\u041C\u0430\u0440\u043A
      \u0410\u0432\u0440\u0435\u043B\u0438\u0439"
  - m_fieldName: tutorial.press_space
    m_keys: 0000000001000000
    m_values:
    - press space to continue the dialogue
    - "\u043D\u0430\u0436\u043C\u0438 \u043F\u0440\u043E\u0431\u0435\u043B \u0447\u0442\u043E\u0431\u044B
      \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C \u0434\u0438\u0430\u043B\u043E\u0433"
  - m_fieldName: tutorial.door_warehouse
    m_keys: 0100000000000000
    m_values:
    - "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 F, \u0447\u0442\u043E\u0431\u044B
      \u043F\u0435\u0440\u0435\u043C\u0435\u0441\u0442\u0438\u0442\u044C\u0441\u044F
      \u043D\u0430 \u0441\u043A\u043B\u0430\u0434"
    - "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 F \u0432\u043E\u0437\u043B\u0435
      \u0434\u0432\u0435\u0440\u0438, \u0447\u0442\u043E\u0431\u044B \u043F\u0435\u0440\u0435\u043C\u0435\u0441\u0442\u0438\u0442\u044C\u0441\u044F
      \u043D\u0430 \u0441\u043A\u043B\u0430\u0434"
  - m_fieldName: tutorial.router_hint
    m_keys: 0000000001000000
    m_values:
    - 'Go to the router and press [E]'
    - "\u041F\u043E\u0434\u043E\u0439\u0434\u0438\u0442\u0435 \u043A \u0440\u043E\u0443\u0442\u0435\u0440\u0443
      \u0438 \u043D\u0430\u0436\u043C\u0438\u0442\u0435 [E]"
  - m_fieldName: tutorial.return_press_f
    m_keys: 0000000001000000
    m_values:
    - "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 F \u0432\u043E\u0437\u043B\u0435
      \u0434\u0432\u0435\u0440\u0438, \u0447\u0442\u043E\u0431\u044B \u043F\u0435\u0440\u0435\u043C\u0435\u0441\u0442\u0438\u0442\u044C\u0441\u044F
      \u043E\u0431\u0440\u0430\u0442\u043D\u043E"
    - "\u0434\u043B\u044F \u0442\u043E\u0433\u043E \u0447\u0442\u043E\u0431\u044B
      \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F [F] \u0443 \u0434\u0432\u0435\u0440\u0438"
  - m_fieldName: tutorial.phone_hint
    m_keys: 0000000001000000
    m_values:
    - Go to the phone and press [E] to pick it up.
    - "\u041F\u043E\u0434\u043E\u0439\u0434\u0438\u0442\u0435 \u043A \u0442\u0435\u043B\u0435\u0444\u043E\u043D\u0443
      \u0438 \u043D\u0430\u0436\u043C\u0438\u0442\u0435 [E], \u0447\u0442\u043E\u0431\u044B
      \u0432\u0437\u044F\u0442\u044C \u0435\u0433\u043E."
  - m_fieldName: tutorial.phone_call_provider
    m_keys: 0100000000000000
    m_values:
    - "\u041D\u0430\u0431\u0435\u0440\u0438\u0442\u0435 \u043D\u043E\u043C\u0435\u0440
      \u043F\u0440\u043E\u0432\u0430\u0439\u0434\u0435\u0440\u0430 \u0438 \u043D\u0430\u0436\u043C\u0438\u0442\u0435
      \u0432\u044B\u0437\u043E\u0432."
    - Dial the provider's number and press call.
  - m_fieldName: tutorial.phone_put
    m_keys: 0000000001000000
    m_values:
    - to put the phone down, press E again
    - "\u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u044C
      \u0442\u0435\u043B\u0435\u0444\u043E\u043D \u043D\u0430\u0436\u043C\u0438 \u0441\u043D\u043E\u0432\u0430
      \u0415"
  - m_fieldName: tutorial.radio_use
    m_keys: 0000000001000000
    m_values:
    - Go to the radio and press E to turn it on
    - "\u043F\u043E\u0434\u043E\u0439\u0434\u0438 \u043A \u0440\u0430\u0434\u0438\u043E
      \u0438 \u043D\u0430\u0436\u043C\u0438 \u0415 \u0447\u0442\u043E\u0431\u044B
      \u0432\u043A\u043B\u044E\u0447\u0438\u0442\u044C \u0435\u0433\u043E"
  - m_fieldName: tutorial.meet_client
    m_keys: 0000000001000000
    m_values:
    - To meet with the client, go to the counter and press [E].
    - "\u0414\u043B\u044F \u0432\u0441\u0442\u0440\u0435\u0447\u0438 \u0441 \u043A\u043B\u0438\u0435\u043D\u0442\u043E\u043C
      \u043F\u043E\u0434\u043E\u0439\u0434\u0438\u0442\u0435 \u043A \u0441\u0442\u043E\u0439\u043A\u0435
      \u0438 \u043D\u0430\u0436\u043C\u0438\u0442\u0435 [E]."
  - m_fieldName: tutorial.go_warehouse
    m_keys: 0000000001000000
    m_values:
    - Press F to move to the warehouse
    - "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 F, \u0447\u0442\u043E\u0431\u044B
      \u043F\u0435\u0440\u0435\u043C\u0435\u0441\u0442\u0438\u0442\u044C\u0441\u044F
      \u043D\u0430 \u0441\u043A\u043B\u0430\u0434"
  - m_fieldName: tutorial.warehouse_pick
    m_keys: 0000000001000000
    m_values:
    - "\u0447\u0442\u043E\u0431\u044B \u0432\u0437\u044F\u0442\u044C \u043F\u043E\u0441\u044B\u043B\u043A\u0443
      \u043F\u043E\u0434\u043E\u0439\u0434\u0438\u0442\u0435 \u043A \u043D\u0435\u0439
      \u0438 \u043D\u0430\u0436\u043C\u0438\u0442\u0435 \u0415"
    - "\u0447\u0442\u043E\u0431\u044B \u0432\u0437\u044F\u0442\u044C \u043F\u043E\u0441\u044B\u043B\u043A\u0443
      \u043F\u043E\u0434\u043E\u0439\u0434\u0438\u0442\u0435 \u043A \u043D\u0435\u0439
      \u0438 \u043D\u0430\u0436\u043C\u0438\u0442\u0435 \u0415"
  - m_fieldName: tutorial.empty
    m_keys: 0000000001000000
    m_values:
    - '              '
    - '                                       '
  - m_fieldName: tutorial.return_to_client
    m_keys: 0000000001000000
    m_values:
    - "\u0432\u043E\u0437\u043C\u0438 \u043F\u043E\u0441\u044B\u043B\u043A\u0443
      \u0415"
    - "\u0447\u0442\u043E\u0431\u044B \u0432\u0437\u044F\u0442\u044C \u043F\u043E\u0441\u044B\u043B\u043A\u0443
      \u043F\u043E\u0434\u043E\u0439\u0434\u0438\u0442\u0435 \u043A \u043D\u0435\u0439
      \u0438 \u043D\u0430\u0436\u043C\u0438\u0442\u0435 \u0415"
  - m_fieldName: tutorial.warehouse_return
    m_keys: 0000000001000000
    m_values:
    - 
    - "\u0443\u0439\u0434\u0438 \u0441\u043E \u0441\u043A\u043B\u0430\u0434\u0430"
  m_nextLanguageID: 0
  m_nextFieldID: 15
