        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: Dialogue Text
        value: "\u041D\u0443, \u0442\u0430\u043A \u0438 \u0447\u0435 \u0441 \u044D\u0442\u0438\u043C\u0438
