        typeString: CustomFieldType_Actor
      - title: Conversant
        value: 1
        type: 5
        typeString: CustomFieldType_Actor
      - title: Menu Text
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: Dialogue Text
        value: "\u0412\u043E\u0437\u043C\u043E\u0436\u043D\u044B \u0438 \u043F\u0435\u0440\u0435\u0431\u043E\u0438
          \u0441 \u044D\u043B\u0435\u043A\u0442\u0440\u0438\u0447\u0435\u0441\u0442\u0432\u043E\u043C
          \u2014 \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u043E\u0432\u043E\u0433\u043E,
          \u0432\u044B \u0436\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0442\u0435. "
        type: 0
        typeString: CustomFieldType_Text
      - title: Sequence
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: en
        value: "There may also be power outages \u2014 nothing new, as you understand."
        type: 4
        typeString: CustomFieldType_Localization
      conversationID: 27
      isRoot: 0
      isGroup: 0
      nodeColor: 
      delaySimStatus: 0
      falseConditionAction: Block
      conditionPriority: 2
      outgoingLinks:
