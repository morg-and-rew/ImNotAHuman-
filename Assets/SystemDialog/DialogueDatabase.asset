        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: Dialogue Text
        value: "\u0427\u0451-\u0451-\u0451? \u041D\u0435\u0442 \u0443\u0436, \u0434\u0435\u043B\u0430\u0439\u0442\u0435
