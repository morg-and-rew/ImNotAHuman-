        typeString: CustomFieldType_Actor
      - title: Menu Text
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: Dialogue Text
        value: "\u0425\u043E\u0442\u044F\u2026 \u044F \u0445\u043E\u0442\u0435\u043B
          \u0441\u043A\u0430\u0437\u0430\u0442\u044C \u2014 \u0441\u0432\u044F\u0437\u044C
          \u0438 \u0438\u043D\u0442\u0435\u0440\u043D\u0435\u0442. \u041A\u043E\u043D\u0435\u0447\u043D\u043E
          \u0436\u0435, \u0441\u0432\u044F\u0437\u044C \u0438 \u0438\u043D\u0442\u0435\u0440\u043D\u0435\u0442. "
        type: 0
        typeString: CustomFieldType_Text
      - title: Sequence
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: en
        value: Though it's better to say "May the connection and electricity be with
          you'.
        type: 4
        typeString: CustomFieldType_Localization
