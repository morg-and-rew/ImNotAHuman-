      - title: Menu Text
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: Dialogue Text
        value: "\u0417\u0430 \u043E\u043A\u043D\u043E\u043C \u0442\u0443\u043C\u0430\u043D\u2026
          \u0442\u0430\u043A \u0447\u0442\u043E \u043F\u0440\u043E\u0441\u044C\u0431\u0430
          \u043A \u0430\u0432\u0442\u043E\u043C\u043E\u0431\u0438\u043B\u0438\u0441\u0442\u0430\u043C"
        type: 0
        typeString: CustomFieldType_Text
      - title: Sequence
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: en
        value: It's foggy outside, so we ask drivers and pedestrians
        type: 4
        typeString: CustomFieldType_Localization
      conversationID: 27
      isRoot: 0
      isGroup: 0
      nodeColor: 
