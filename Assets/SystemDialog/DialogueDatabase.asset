      - title: Menu Text
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: Dialogue Text
        value: "\u0421\u0435\u0433\u043E\u0434\u043D\u044F 15 \u0438\u044E\u043B\u044F,
          \u043D\u0430 \u0447\u0430\u0441\u0430\u0445 10:13 \u2014 \u0438 \u043C\u044B,
          \u043A\u0430\u043A \u043E\u0431\u044B\u0447\u043D\u043E, \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u043C
          \u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0439 \u044D\u0444\u0438\u0440."
        type: 0
        typeString: CustomFieldType_Text
      - title: Sequence
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: en
