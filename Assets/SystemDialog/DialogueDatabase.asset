      - title: Conversant
        value: 1
        type: 5
        typeString: CustomFieldType_Actor
      - title: Menu Text
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: Dialogue Text
        value: "\u041D\u043E \u043D\u0435 \u0432\u043E\u043B\u043D\u0443\u0439\u0442\u0435\u0441\u044C:
          \u0440\u0430\u043D\u043E \u0438\u043B\u0438 \u043F\u043E\u0437\u0434\u043D\u043E
          \u043F\u0440\u0430\u0437\u0434\u043D\u0438\u043A \u0431\u0443\u0434\u0435\u0442
          \u0438 \u043D\u0430 \u043D\u0430\u0448\u0435\u0439 \u0443\u043B\u0438\u0446\u0435."
        type: 0
        typeString: CustomFieldType_Text
      - title: Sequence
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: en
        value: But don't worry! May the Force be with you!
        type: 4
        typeString: CustomFieldType_Localization
      conversationID: 27
      isRoot: 0
      isGroup: 0
      nodeColor: 
      delaySimStatus: 0
      falseConditionAction: Block
