      - title: Menu Text
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: Dialogue Text
        value: "\u0438 \u043F\u0435\u0448\u0435\u0445\u043E\u0434\u0430\u043C \u2014
          \u0431\u0443\u0434\u044C\u0442\u0435 \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E
          \u0432\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u044B."
        type: 0
        typeString: CustomFieldType_Text
      - title: Sequence
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: en
        value: to be especially careful.
        type: 4
        typeString: CustomFieldType_Localization
      conversationID: 27
      isRoot: 0
      isGroup: 0
      nodeColor: 
