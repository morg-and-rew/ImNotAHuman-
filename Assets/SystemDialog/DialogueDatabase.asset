        value: "\"\u041F\u0435\u0440\u0432\u044B\u0439 \u043F\u0440\u0438\u0437\u043D\u0430\u043A
          - \u043D\u0430 \u0433\u043E\u0440\u043E\u0434 \u043E\u043F\u0443\u0441\u043A\u0430\u0435\u0442\u0441\u044F
