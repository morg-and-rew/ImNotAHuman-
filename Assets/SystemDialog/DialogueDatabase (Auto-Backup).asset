        type: 0
        typeString: CustomFieldType_Text
      - title: Dialogue Text
        value: "\u0410 \u0442\u0435\u043F\u0435\u0440\u044C \u2013 \u043C\u0443\u0437\u044B\u043A\u0430\u043B\u044C\u043D\u0430\u044F
