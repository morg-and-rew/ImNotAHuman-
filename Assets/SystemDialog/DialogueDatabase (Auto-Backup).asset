      - title: Menu Text
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: Dialogue Text
        value: "\u041D\u0430\u043B\u0438\u0432\u0430\u0439\u0442\u0435 \u043A\u0440\u0435\u043F\u043A\u0438\u0439
          \u043A\u043E\u0444\u0435 \u0438\u043B\u0438 \u0447\u0435\u0433\u043E-\u043D\u0438\u0431\u0443\u0434\u044C
          \u043F\u043E\u043A\u0440\u0435\u043F\u0447\u0435 \u0438 \u043D\u0430\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0439\u0442\u0435\u0441\u044C
          \u043D\u0430 \u043F\u0440\u043E\u0434\u0443\u043A\u0442\u0438\u0432\u043D\u044B\u0439
          \u0434\u0435\u043D\u044C."
        type: 0
        typeString: CustomFieldType_Text
      - title: Sequence
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: en
        value: Pour strong coffee or something stronger and tune in for a productive
          day.
        type: 4
        typeString: CustomFieldType_Localization
      conversationID: 6
