        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: Dialogue Text
        value: "\u0414\u043E\u0431\u0440\u043E\u0435 \u0443\u0442\u0440\u043E, \u0436\u0438\u0442\u0435\u043B\u0438
          \u043D\u0430\u0448\u0435\u0433\u043E \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u043E\u0433\u043E
          \u0433\u043E\u0440\u043E\u0434\u0430! "
        type: 0
        typeString: CustomFieldType_Text
      - title: Sequence
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: en
        value: Good morning, residents of our beautiful city! Today is July 13th,
          it's 10:07 on the clock, which means the morning news is on the air.
        type: 4
