        type: 5
        typeString: CustomFieldType_Actor
      - title: Menu Text
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: Dialogue Text
        value: "\u0412\u0438\u0434\u0438\u043C\u043E, \u043D\u0430\u0448 \u0434\u043E\u0440\u043E\u0433\u043E\u0439
          \u043D\u0430\u0443\u0447\u043D\u043E-\u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u0438\u0439
          \u0438\u043D\u0441\u0442\u0438\u0442\u0443\u0442 \u0433\u043E\u0442\u043E\u0432\u0438\u0442
          \u043A\u0430\u043A\u043E\u0439-\u0442\u043E \u0430\u043F\u043F\u0430\u0440\u0430\u0442
          \u0434\u043B\u044F \u0441\u043C\u0435\u043D\u044B \u043F\u043E\u0433\u043E\u0434\u044B,
          \u0445\u0430-\u0445\u0430-\u0445\u0430! \u0428\u0443\u0442\u043A\u0430!"
        type: 0
        typeString: CustomFieldType_Text
      - title: Sequence
        value: 
        type: 0
        typeString: CustomFieldType_Text
      - title: en
        value: Apparently, our dear research institute is preparing some kind of
          device to change the weather, ha-ha-ha! Just kidding!
        type: 4
        typeString: CustomFieldType_Localization
      conversationID: 6
      isRoot: 0
